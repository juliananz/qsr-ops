# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is git-ignored and must never be committed.

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a random salt once with: python -c "import secrets; print(secrets.token_hex(32))"
# Generate each pin_hash with:      python scripts/hash_pin.py
[auth]
salt = "REPLACE_WITH_OUTPUT_OF_secrets.token_hex(32)"

[auth.users]
# username = "pin_hash"   (one entry per person; run scripts/hash_pin.py to generate)
paulina     = "REPLACE_WITH_HASH"
miguel      = "REPLACE_WITH_HASH"
josejulian  = "REPLACE_WITH_HASH"
jorgejulian = "REPLACE_WITH_HASH"
# ─────────────────────────────────────────────────────────────────────────────

ANALYTICS_GITHUB_TOKEN = "ghp_your_token_here"
DRIVE_GASTOS_FOLDER_ID = "1XgtpdbAMJ-wnLjImeMfE8UzcknjIUtFJ"

# Paste the full JSON content of your service account key file as a string.
# Example (replace all values with your actual service account data):
# GOOGLE_CREDENTIALS_JSON = '''
# {
#   "type": "service_account",
#   "project_id": "your-project-id",
#   "private_key_id": "...",
#   "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
#   "client_email": "your-sa@your-project.iam.gserviceaccount.com",
#   "client_id": "...",
#   "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#   "token_uri": "https://oauth2.googleapis.com/token"
# }
# '''
GOOGLE_CREDENTIALS_JSON = ""
